def calcular_preco(distancia, chovendo):
    tx_5_km = 5
    tx_5_10_km = 8
    tx_10_km = 10
    tx_chovendo = 2

    if distancia < 5:
        preco = tx_5_km
    elif distancia <= 10:
        preco = tx_5_10_km
    else:
        preco = tx_10_km

    if chovendo:
        preco += tx_chovendo

    return preco


# Entrada do usuário
distancia = float(input("Digite a distância em km: "))
resposta = input("Está chovendo? (s/n): ").lower()

chovendo = True if resposta == "s" else False

valor = calcular_preco(distancia, chovendo)

print("Preço a pagar: R$", valor)